{
  "permissions": {
    "allow": [
      "mcp__livekit-docs__docs_search",
      "Skill(superpowers:using-superpowers)",
      "Skill(superpowers:using-superpowers:*)",
      "Bash(mix test *)",
      "Bash(python3 -c ' *)",
      "Skill(ping-pong)",
      "Skill(ping-pong:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-scratch.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-scratch.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-scratch.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-scratch.sh"
          }
        ]
      }
    ]
  }
}
